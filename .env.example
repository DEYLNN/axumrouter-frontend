# AxumRouter Frontend — Environment Variables
# Copy this to .env and fill in your values.

# ⚠️ API base URL — include FULL path with /admin/api suffix
# Dev (Vite proxy):   leave empty (falls back to /admin/api)
# Production (VPS):   http://152.42.198.51:3000/admin/api
# Production (domain): https://axm-api.dkzhen.org/admin/api
VITE_API_BASE=

# Gateway backend URL (for display on Endpoint page)
# Example: VITE_GATEWAY_BACKEND_URL=http://152.42.198.51:3000
VITE_GATEWAY_BACKEND_URL=
