# AxumRouter Frontend — Environment Variables
# Copy this to .env and fill in your values.

# Vite API base URL. In dev mode (Vite proxy), leave empty to use /admin/api.
# In production (Vercel/static), set to your backend URL:
# Example: VITE_API_BASE=https://api.axumrouter.com
VITE_API_BASE=

# Gateway backend URL (overrides settings' public_ip:port display)
# Example: VITE_GATEWAY_BACKEND_URL=http://203.0.113.10:3000
VITE_GATEWAY_BACKEND_URL=
